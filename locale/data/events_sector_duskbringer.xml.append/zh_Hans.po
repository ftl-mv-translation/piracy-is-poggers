#: src-en/data/events_sector_duskbringer.xml.append:53
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING\"]/mod-"
"append:choice/text"
msgstr "（海盗声望 1+）向他们喊话。"

#: src-en/data/events_sector_duskbringer.xml.append:55
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING\"]/mod-"
"append:choice/event/text"
msgstr "海盗们认出了你，放松了警惕。“哎哟，这不是咱们的联邦哥们儿嘛。我们一直想回海盗星区去，可那些绿皮怪胎老是把我们的船给打爆。现在我们被困在这儿，正计划集体突围呢，但附近有艘看着很凶的精英巡逻舰挡着。你看这样如何——帮我们干掉那艘船？报酬好商量，火力支援也管够。”"

#: src-en/data/events_sector_duskbringer.xml.append:57
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING\"]/mod-"
"append:choice/event/choice[1]/text"
msgstr "同意。"

#: src-en/data/events_sector_duskbringer.xml.append:59
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING\"]/mod-"
"append:choice/event/choice[1]/event/text"
msgstr "“太好了。跟我们来……”你被带到了一艘精英级的暮临派战舰前，对方一见到你就立刻发起了攻击。海盗们倒也算守信用，从侧翼提供了火力支援，但这依然会是一场恶战。"

#: src-en/data/events_sector_duskbringer.xml.append:63
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING\"]/mod-"
"append:choice/event/choice[1]/event/choice/text"
msgstr "继续。"

#: src-en/data/events_sector_duskbringer.xml.append:69
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING\"]/mod-"
"append:choice/event/choice[2]/text"
msgstr "拒绝他们的提议。"

#: src-en/data/events_sector_duskbringer.xml.append:71
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING\"]/mod-"
"append:choice/event/choice[2]/event/text"
msgstr "“啊好吧，看来你也被那些纳粹疯子搞得够呛，嗯？既然你来了，咱们做笔交易如何？”"

#: src-en/data/events_sector_duskbringer.xml.append:80
msgid ""
"data/events_sector_duskbringer.xml.append$//event[@name=\"DUSK_PIRATES_HIDING_VICTORY\"]/text"
msgstr "那艘精英暮临派飞船已坠毁。你拆解了残骸"

#: src-en/data/events_sector_duskbringer.xml.append:83
msgid ""
"data/events_sector_duskbringer.xml.append$//event[@name=\"DUSK_PIRATES_HIDING_VICTORY\"]/choice/text"
msgstr "联系海盗。"

#: src-en/data/events_sector_duskbringer.xml.append:85
msgid ""
"data/events_sector_duskbringer.xml.append$//event[@name=\"DUSK_PIRATES_HIDING_VICTORY\"]/choice/event/text"
msgstr "“不得不说，刚才那场打得真够带劲。多谢帮忙。这是答应你的报酬。”"

#: src-en/data/events_sector_duskbringer.xml.append:88
msgid ""
"data/events_sector_duskbringer.xml.append$//event[@name=\"DUSK_PIRATES_HIDING_VICTORY\"]/choice/event/choice/text"
msgstr "继续。"

#: src-en/data/events_sector_duskbringer.xml.append:97
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING_CONTACT\"]/mod:findWithChildLike/mod:selector"
msgstr "令人惊讶的是，当你靠近时，没有一个海盗移动。其中一人向你打招呼，要求你明确意图。"

#: src-en/data/events_sector_duskbringer.xml.append:99
msgid ""
"data/events_sector_duskbringer.xml.append$//mod:findName[@name=\"DUSK_PIRATES_HIDING_CONTACT\"]/mod:findWithChildLike/mod:findWithChildLike/mod:selector"
msgstr "攻击！"

