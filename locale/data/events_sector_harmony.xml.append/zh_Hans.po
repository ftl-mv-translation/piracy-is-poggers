#: src-en/data/events_sector_harmony.xml.append:31
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/text"
msgstr "（走私者声望3+）呼叫他们，并向他们保证你无意伤害他们。"

#: src-en/data/events_sector_harmony.xml.append:33
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/text"
msgstr "“哦，是你们啊。我们这儿有位重要人物，呃……跟半械巡逻队关系不太好。我们在这个星区被追得够呛，介意接手吗？”"

#: src-en/data/events_sector_harmony.xml.append:35
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[1]/text"
msgstr "当然。"

#: src-en/data/events_sector_harmony.xml.append:37
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[1]/event/text"
msgstr "“太好了，谢谢你帮我卸下这个担子。再给你们一些补给吧。”走私者们送来了一个颜色奇特的半械保卫者。"

#: src-en/data/events_sector_harmony.xml.append:40
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[1]/event/choice/text"
msgstr "继续。"

#: src-en/data/events_sector_harmony.xml.append:42
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[1]/event/choice/event/text"
msgstr "“离开星区的主要运输工具已放弃任务。请求：将我本人运出谐合星区。会支付报酬。”"

#: src-en/data/events_sector_harmony.xml.append:44
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[1]/event/choice/event/choice[1]/text"
msgstr "接受。"

#: src-en/data/events_sector_harmony.xml.append:51
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[1]/event/choice/event/choice[2]/text"
msgstr "拒绝。"

#: src-en/data/events_sector_harmony.xml.append:59
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[2]/text"
msgstr "不，谢谢。"

#: src-en/data/events_sector_harmony.xml.append:61
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[2]/event/text"
msgstr "“可惜了。那我们会尽力不被半械巡逻队炸飞的。”你祝他们好运，并趁这段时间在船上做点什么。"

#: src-en/data/events_sector_harmony.xml.append:63
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[2]/event/choice[1]/text"
msgstr "星舰管理。"

#: src-en/data/events_sector_harmony.xml.append:67
msgid ""
"data/events_sector_harmony.xml.append$//mod:findName[@name=\"TURZIL_PIRATE_TRANSPORT\"]/mod-"
"append:choice/event/choice[2]/event/choice[2]/text"
msgstr "跳过。"
