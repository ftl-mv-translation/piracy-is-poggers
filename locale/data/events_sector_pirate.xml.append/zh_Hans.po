#: src-en/data/events_sector_pirate.xml.append:426
msgid ""
"data/events_sector_pirate.xml.append$//mod:findName[@name=\"DISTRESS_PIRATE_VAMPWEED\"]/mod:findWithChildLike/mod:selector"
msgstr "等待奴隶贩子抓住猎物。"

#: src-en/data/events_sector_pirate.xml.append:677
msgid ""
"data/events_sector_pirate.xml.append$//event[@name=\"PIP_QUEST_PIRATE_HUB\"]/text"
msgstr "附近的空间站已被改建为海盗枢纽。你可以看到相当数量的海盗在空间站里进进出出，而缺乏正规安保措施则表明这里的海盗彼此信任，相信能维持基本的秩序。你琢磨着什么样的海盗才会信任另一个海盗，但如果你想要进入，应该也不会被拒绝。"

#: src-en/data/events_sector_pirate.xml.append:679
msgid ""
"data/events_sector_pirate.xml.append$//event[@name=\"PIP_QUEST_PIRATE_HUB\"]/choice[1]/text"
msgstr "进入枢纽。"

#: src-en/data/events_sector_pirate.xml.append:683
